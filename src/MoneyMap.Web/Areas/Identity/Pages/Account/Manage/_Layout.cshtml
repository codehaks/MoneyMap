@{
    Layout = "/Areas/Users/Pages/Shared/_Layout.cshtml";
    ViewBag.Title = ViewData["Title"];
}

<header class="mm-page-head">
    <div>
        <span class="mm-eyebrow">Account</span>
        <h1>Manage your account</h1>
        <p>Change your profile, security, and data settings.</p>
    </div>
</header>

<div class="mm-subgrid">
    <aside class="mm-subnav">
        <partial name="_ManageNav" />
    </aside>
    <section class="mm-subcontent">
        @RenderBody()
    </section>
</div>

@section scripts {
    @RenderSection("Scripts", required: false)
}
