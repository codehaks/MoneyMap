@page
@model MoneyMap.Web.Areas.Admin.Pages.Categories.IndexModel
@{
    ViewBag.Title = "Categories";
}

<header class="mm-page-head">
    <div>
        <span class="mm-eyebrow">Administration</span>
        <h1>Categories</h1>
        <p>Manage the expense categories users can pick from.</p>
    </div>
</header>

<div class="table-responsive">
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th scope="col">Id</th>
                <th scope="col">Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model.Categories)
            {
                <tr>
                    <td>@category.Id</td>
                    <td>@category.Name</td>
                </tr>
            }
        </tbody>
    </table>
</div>
